# Copy to .env and fill in your key. Only ANTHROPIC_API_KEY is required.
# API credits live at console.anthropic.com (NOT the claude.ai subscription).
ANTHROPIC_API_KEY=

# --- Models (current IDs; override only if you know why) ---
VIGIL_TRIAGE_MODEL=claude-sonnet-4-6
VIGIL_CLINICAL_MODEL=claude-sonnet-4-6
VIGIL_PREFILTER_MODEL=claude-haiku-4-5-20251001

# --- Behaviour ---
# temperature=0 keeps classifier output reproducible (defensible eval numbers).
VIGIL_TEMPERATURE=0
VIGIL_PROMPT_VERSION=v2
VIGIL_SCHEMA_VERSION=v1
# Per-request timeout (s) and SDK retries — a stalled socket can't hang a run.
VIGIL_REQUEST_TIMEOUT=60
VIGIL_MAX_RETRIES=3

# --- Storage / retrieval ---
VIGIL_DB_PATH=vigil.db
# tfidf (default, zero-download) | fastembed (optional, needs: uv sync --extra semantic)
VIGIL_EMBEDDER=tfidf

# --- Webhook ingestion (optional; only for the `make webhook` service) ---
# Set a per-platform secret to ENFORCE HMAC signature verification for that platform.
# A single VIGIL_WEBHOOK_SECRET applies to all platforms as a fallback.
# VIGIL_WEBHOOK_SECRET=
# VIGIL_WEBHOOK_SECRET_SHOPIFY=
# VIGIL_WEBHOOK_SECRET_ZENDESK=
# VIGIL_WEBHOOK_SECRET_GORGIAS=
# Fail closed (reject unsigned) even when no secret is configured:
# VIGIL_WEBHOOK_REQUIRE_SIGNATURE=false
