# Copy to .env and fill in a key. You need ONE of: ANTHROPIC_API_KEY, or a free
# OpenAI-compatible provider (set VIGIL_LLM_PROVIDER=openai + a key below).

# --- Option 1: Anthropic (default; what the eval proof was run on) ---
# Credits live at console.anthropic.com (NOT the claude.ai subscription).
ANTHROPIC_API_KEY=

# --- Option 2: a FREE OpenAI-compatible provider (e.g. Groq hosting Moonshot's Kimi K2) ---
# Uncomment these to run the demo for free. Get a free key at https://console.groq.com/
# VIGIL_LLM_PROVIDER=openai
# GROQ_API_KEY=
# VIGIL_LLM_BASE_URL=https://api.groq.com/openai/v1
# VIGIL_LLM_MODEL=openai/gpt-oss-120b   # strong free model; also try llama-3.3-70b-versatile
# Other OpenAI-compatible options (set base_url + key + model accordingly):
#   Moonshot direct: https://api.moonshot.ai/v1            (MOONSHOT key via VIGIL_LLM_API_KEY)
#   Google Gemini  : https://generativelanguage.googleapis.com/v1beta/openai/
#   DeepSeek       : https://api.deepseek.com/v1
#   OpenRouter     : https://openrouter.ai/api/v1

# --- Models (Anthropic path; ignored when VIGIL_LLM_PROVIDER=openai) ---
VIGIL_TRIAGE_MODEL=claude-sonnet-4-6
VIGIL_CLINICAL_MODEL=claude-sonnet-4-6
VIGIL_PREFILTER_MODEL=claude-haiku-4-5-20251001

# --- Behaviour ---
# temperature=0 keeps classifier output reproducible (defensible eval numbers).
VIGIL_TEMPERATURE=0
VIGIL_PROMPT_VERSION=v2
VIGIL_SCHEMA_VERSION=v1
# Per-request timeout (s) and SDK retries — a stalled socket can't hang a run.
VIGIL_REQUEST_TIMEOUT=60
VIGIL_MAX_RETRIES=3

# --- Storage / retrieval ---
VIGIL_DB_PATH=vigil.db
# tfidf (default, zero-download) | fastembed (optional, needs: uv sync --extra semantic)
VIGIL_EMBEDDER=tfidf

# --- Webhook ingestion (optional; only for the `make webhook` service) ---
# Set a per-platform secret to ENFORCE HMAC signature verification for that platform.
# A single VIGIL_WEBHOOK_SECRET applies to all platforms as a fallback.
# VIGIL_WEBHOOK_SECRET=
# VIGIL_WEBHOOK_SECRET_SHOPIFY=
# VIGIL_WEBHOOK_SECRET_ZENDESK=
# VIGIL_WEBHOOK_SECRET_GORGIAS=
# Fail closed (reject unsigned) even when no secret is configured:
# VIGIL_WEBHOOK_REQUIRE_SIGNATURE=false

# --- Outbound (post the triage back to the source ticket) ---
# off | dry_run (default — records intent, no HTTP) | live (calls the platform API)
# VIGIL_OUTBOUND_MODE=dry_run
# Allow a grounded auto_send reply to be posted PUBLICLY (never for clinical/MDR). Default false.
# VIGIL_OUTBOUND_ALLOW_AUTOSEND_PUBLIC=false
# Credentials (only needed for VIGIL_OUTBOUND_MODE=live):
# VIGIL_ZENDESK_SUBDOMAIN=        VIGIL_ZENDESK_EMAIL=        VIGIL_ZENDESK_API_TOKEN=
# VIGIL_SHOPIFY_DOMAIN=           VIGIL_SHOPIFY_ACCESS_TOKEN= VIGIL_SHOPIFY_API_VERSION=2024-10
# VIGIL_GORGIAS_DOMAIN=           VIGIL_GORGIAS_EMAIL=        VIGIL_GORGIAS_API_KEY=
